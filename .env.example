# ----------------------------------------------------------------------------
# CarbonTrace environment variables
#
# Milestone 1 (scaffold + landing) runs with NO keys at all — every external
# service is behind a graceful adapter that degrades to a safe stub when its
# key is absent (see lib/adapters/README.md). Fill these in as later
# milestones come online.
# ----------------------------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Email (Resend) — contact form. Without this the message is logged server-side.
RESEND_API_KEY=
EMAIL_FROM="CarbonTrace <onboarding@resend.dev>"

# AI (Groq) — powers ALL AI operations (footprint insights, recommendations).
# OpenAI-compatible API; the key stays server-side. Without it the insights
# demo returns deterministic sample data so the flow still works.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- The following are consumed by later milestones (kept for reference) ----

# Database (Vercel Postgres / Neon) — Milestone 2
DATABASE_URL=
DIRECT_URL=

# Auth.js (NextAuth v5) — Milestone 2
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Vercel KV (Upstash) — rate limiting / caching
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Stripe — subscriptions + offset checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=

# Vercel Blob — PDF report storage
BLOB_READ_WRITE_TOKEN=

# Integrations (optional)
PLAID_CLIENT_ID=
PLAID_SECRET=

# Cron / monitoring
CRON_SECRET=
SENTRY_DSN=
